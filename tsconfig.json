{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": false,
    "useUnknownInCatchVariables": true,
    "noPropertyAccessFromIndexSignature": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@sdk/*": [
        "src/generated/client/*"
      ],
      "@castellan/core/*": [
        "src/core/*"
      ],
      "@castellan/engine/*": [
        "src/engine/*"
      ],
      "@castellan/client/*": [
        "src/client/core/*"
      ],
      "@ui-lib": [
        "src/client/ui-lib/index.ts"
      ],
      "@castellan/api/*": [
        "src/generated/*"
      ]
    },
    "allowJs": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "tmp",
    "scratch",
    "dist"
  ]
}